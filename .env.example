WHISPER_MODEL=large-v3
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=it
WHISPER_VAD_FILTER=true
WHISPER_WORD_TIMESTAMPS=false
WHISPER_DOWNLOAD_ROOT=/models
# Parallel transcriptions per container, and CPU threads each. Keep their
# product <= CPU cores (e.g. 2 * 8 = 16). See CELERY_CONCURRENCY below.
OMP_NUM_THREADS=8
WHISPER_CPU_THREADS=8

S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_NAME=corabea
S3_REGION=us-east-1
S3_USE_SSL=False
RECORDINGS_PREFIX=recordings
TRANSCRIPTIONS_PREFIX=transcriptions

REDIS_URL=redis://redis:6379/0
REDIS_USE_SSL=False
CELERY_QUEUE_PREFIX=...
CELERY_CONCURRENCY=1        # parallel transcriptions per container

MIN_OBJECT_AGE_SECONDS=120
MAX_AUDIO_MB=1000
REQUEUE_DELAY_SECONDS=120
CELERY_MAX_RETRIES=20
